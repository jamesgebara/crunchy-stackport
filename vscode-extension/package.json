  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "aws",
    "localstack",
    "cloud",
    "emulator",
    "developer-tools"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "repository": {
