{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run StackPort Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/vscode-extension"],
      "outFiles": ["${workspaceFolder}/vscode-extension/out/**/*.js"],
      "preLaunchTask": "npm: compile - vscode-extension"
    }
  ]
}
